{
  "title": "XDC Plugin Node Monitor",
  "uid": "plugin-nodes",
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Node Status (Up/Down)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "noValue": "DOWN"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job=\"plugin_nodes\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "XDC Balance (XDC)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "green", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "eth_balance{job=\"plugin_nodes\"}",
          "legendFormat": "{{node}} ({{account}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "XDC Balance over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "eth_balance{job=\"plugin_nodes\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "RPC Call Failure Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * rate(evm_pool_rpc_node_calls_failed{job=\"plugin_nodes\"}[5m]) / (rate(evm_pool_rpc_node_calls_total{job=\"plugin_nodes\"}[5m]) + 0.001)",
          "legendFormat": "{{node}} - {{nodeName}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "RPC Dial Failure Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * rate(evm_pool_rpc_node_dials_failed{job=\"plugin_nodes\"}[5m]) / (rate(evm_pool_rpc_node_dials_total{job=\"plugin_nodes\"}[5m]) + 0.001)",
          "legendFormat": "{{node}} - {{nodeName}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "DB Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "db_conns_open{job=\"plugin_nodes\"}",
          "legendFormat": "{{node}} - open",
          "refId": "A"
        },
        {
          "expr": "db_conns_used{job=\"plugin_nodes\"}",
          "legendFormat": "{{node}} - used",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Network Connectivity Failures (cumulative)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "block_history_estimator_connectivity_failure_count{job=\"plugin_nodes\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {}
}
